{
	"mcpServers": {
		"astro-mcp": {
			"command": "npx",
			"args": ["-y", "@astrojs/mcp-server"],
			"description": "Astro framework operations"
		},
		"github": {
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-github"],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT_HERE"
			},
			"description": "GitHub integration for repository management, issues, and pull requests"
		},
		"playwright-mcp": {
			"command": "npx",
			"args": ["@playwright/mcp@latest"],
			"description": "Browser testing and automation"
		},
		"css": {
			"command": "npx",
			"args": ["-y", "css-mcp"]
		},
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp",
				"--api-key",
				"YOUR_CONTEXT7_API_KEY_HERE"
			]
		},
		"TestSprite": {
			"command": "npx",
			"args": ["@testsprite/testsprite-mcp@latest"],
			"env": {
				"API_KEY": "YOUR_TESTSPRITE_API_KEY_HERE"
			}
		},
		"chrome-devtools": {
			"command": "npx",
			"args": ["-y", "chrome-devtools-mcp@latest"]
		}
	}
}
