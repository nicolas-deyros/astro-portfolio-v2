---
interface Props {
	clientName: string
	title?: string
}

const { clientName, title = 'Client Portal' } = Astro.props
---

<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
	<!-- Header -->
	<header
		class="border-b border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
		<div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
			<div>
				<p class="text-xs font-medium tracking-wide text-gray-500 uppercase dark:text-gray-400">
					Client Portal
				</p>
				<h1 class="text-lg font-semibold text-gray-900 dark:text-white">
					{clientName}
				</h1>
			</div>

			<div class="flex items-center gap-4">
				<a
					href="/client/"
					class="text-sm text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
					My Files
				</a>
				<button
					id="client-logout-btn"
					class="rounded-md bg-gray-100 px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600">
					Sign out
				</button>
			</div>
		</div>
	</header>

	<!-- Page title bar -->
	{
		title !== 'Client Portal' && (
			<div class="border-b border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-800">
				<div class="mx-auto max-w-7xl px-4 py-3 sm:px-6 lg:px-8">
					<h2 class="text-sm font-medium text-gray-700 dark:text-gray-300">
						{title}
					</h2>
				</div>
			</div>
		)
	}

	<!-- Content -->
	<main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
		<slot />
	</main>
</div>

<script>
	document.addEventListener('astro:page-load', () => {
		document
			.getElementById('client-logout-btn')
			?.addEventListener('click', async () => {
				try {
					await fetch('/api/client/auth.json', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ action: 'logout' }),
						credentials: 'include',
					})
				} catch {
					// ignore
				} finally {
					window.location.href = '/client/login'
				}
			})
	})
</script>
