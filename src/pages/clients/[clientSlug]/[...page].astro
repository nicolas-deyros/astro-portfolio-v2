---
import Layout from '@layouts/index.astro'
import ClientLayout from '@components/clients/ClientLayout.astro'
import { requireClientAccess, requireClientSession } from '@lib/clientSession'
import { db } from '@lib/db'
import { clientNodes, clients } from '@/db/schema'
import { and, eq } from 'drizzle-orm'

const { clientSlug, page } = Astro.params

if (!clientSlug) return Astro.redirect('/client/login', 302)

const pageSlug = Array.isArray(page) ? page.join('/') : (page ?? '')

const session = await requireClientAccess(Astro.cookies, Astro.request, clientSlug)
if (!session) {
	const currentSession = await requireClientSession(Astro.cookies, Astro.request)
	if (currentSession) return Astro.redirect('/client/', 302)
	return Astro.redirect('/client/login', 302)
}

// If the page slug is registered but no Astro file handles it → 404
const [node] = await db
	.select({ name: clientNodes.name })
	.from(clientNodes)
	.where(
		and(
			eq(clientNodes.clientId, session.clientId),
			eq(clientNodes.pageSlug, pageSlug),
			eq(clientNodes.type, 'page'),
		),
	)
	.limit(1)

const [client] = await db
	.select({ name: clients.name })
	.from(clients)
	.where(eq(clients.id, session.clientId))
	.limit(1)
---

<Layout title="Page Not Found — Client Portal">
	<ClientLayout clientName={client?.name ?? 'Client'} title="Page not found">
		<div class="flex flex-col items-center justify-center py-20 text-gray-400">
			<p class="text-4xl font-bold text-gray-300 dark:text-gray-600">404</p>
			<p class="mt-2 text-sm">
				{node ? 'This page exists but has no content yet.' : 'Page not found.'}
			</p>
			<a
				href="/client/"
				class="mt-6 text-sm text-blue-600 hover:underline dark:text-blue-400">
				← Back to my files
			</a>
		</div>
	</ClientLayout>
</Layout>
